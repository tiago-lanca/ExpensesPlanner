@{
    ViewData["Title"] = "Expenses";
}

@model List<Expense>

<div class="text-center">
    <h1 class="display-4">Expenses</h1>
    <h3>Total Expenses: @ViewBag.Expenses€</h3>
    <hr />

    <table class="table">
        <thead class="thead-light">
            <tr>
                <th scope="col">ID</th>
                <th scope="col">Amount</th>
                <th scope="col">Description</th>
                <th scope="col"></th>
            </tr>
        </thead>
        <tbody>

            @{
                foreach(var expense in Model)
                {
                    <tr>
                        <th scope="row">@expense.Id</th>
                        <td>@expense.Amount</td>
                        <td>@expense.Description</td>
                        <td>
                            <a asp-action="CreateEditExpenses" asp-route-id="@expense.Id">Edit</a>
                            <a asp-action="DeleteExpense" asp-route-id="@expense.Id">Delete</a>
                        </td>
                    </tr> 
                }
            }
        </tbody>
    </table>

    <a class="btn btn-primary" asp-action="CreateEditExpenses">Create Expense</a>
</div>
