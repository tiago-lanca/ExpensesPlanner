@using ExpensesPlanner.ViewModels
@model LoginViewModel

@{
    ViewData["Title"] = "Login";
}


<div class="modal modal-sheet position-static d-block bg-body-secondary p-4 py-md-5" tabindex="-1" role="dialog" id="modalSignin">
  <div class="modal-dialog" role="document">
    <div class="modal-content rounded-4 shadow">
      <div class="modal-header p-5 pb-4 border-bottom-0">
        <h1 class="fw-bold mb-0 fs-2">Login</h1>
        <a class="btn-close pe-auto" aria-label="Close" asp-controller="Home" asp-action="Index"></a>
      </div>

            @{
                if(TempData["Error"] != null)
                {
                    <div class="col align-self-center alert alert-danger">
                        <span><b>Sorry!</b> - @TempData["Error"]</span>
                    </div>
                }
            }
      <div class="modal-body p-5 pt-0">
        <form class="" method="post" asp-action="Login">
            <!-- Email Address -->
          <div class="form-floating mb-3">
            <input type="email" class="form-control rounded-3" asp-for="Email" placeholder="name@example.com">
            <label asp-for="Email">Email address</label>
            <span asp-validation-for="Email" class="text-danger"></span>
          </div>
          <!-- Password -->
          <div class="form-floating mb-3">
            <input type="password" class="form-control rounded-3" asp-for="Password" placeholder="Password">
            <label asp-for="Password">Password</label>
            <span asp-validation-for="Password" class="text-danger"></span>
          </div>
          <!-- Sign in Button -->
          <button class="w-100 mb-2 btn btn-lg rounded-3 btn-primary" type="submit" >Login</button>
          <div class="text-center"><span>Or</span></div>
                    <button class="w-100 mb-2 btn btn-lg rounded-3 btn-primary" asp-action="Register">Sign up</button>
          <small class="text-body-secondary">By clicking Sign up, you agree to the terms of use.</small>
          <hr class="my-4">
          
          <!-- External Login-->

          <!-- <h2 class="fs-5 fw-bold mb-3">Or use a third-party</h2>
          <button class="w-100 py-2 mb-2 btn btn-outline-secondary rounded-3" type="submit">
            <svg class="bi me-1" width="16" height="16"><use xlink:href="#twitter"/></svg>
            Sign up with Twitter
          </button>
          <button class="w-100 py-2 mb-2 btn btn-outline-primary rounded-3" type="submit">
            <svg class="bi me-1" width="16" height="16"><use xlink:href="#facebook"/></svg>
            Sign up with Facebook
          </button>
          <button class="w-100 py-2 mb-2 btn btn-outline-secondary rounded-3" type="submit">
            <svg class="bi me-1" width="16" height="16"><use xlink:href="#github"/></svg>
            Sign up with GitHub
          </button>-->
        </form>
      </div>
    </div>
  </div>
</div>