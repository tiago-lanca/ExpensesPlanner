@using ExpensesPlanner.ViewModels
@{
    ViewData["Title"] = "Users";
}

@model List<AdminDashboardUserViewModel>

<div class="text-center mt-5 pt-5">
    <h1 class="display-4">Users</h1>
    <hr />

    <div class="container mt-4">
        <table class="table">
            <thead class="thead-light">
                <tr>
                    <th scope="col">First Name</th>
                    <th scope="col">Last Name</th>
                    <th scope="col">Phone</th>
                    <th scope="col">Role</th>
                    <th scope="col"></th>
                </tr>
            </thead>
            <tbody>

                @{
                    foreach (var user in Model)
                    {
                        <tr>
                            <th scope="row">@user.FirstName</th>
                            <td>@user.LastName</td>
                            <td>@user.Phone</td>
                            <td>@user.Role</td>
                            <td>
                                <a asp-controller="AdminDashboard" asp-action="Edit" asp-route-id="@user.Id">Edit</a>
                                <a asp-controller="AdminDashboard" asp-action="Delete" asp-route-id="@user.Id">Delete</a>
                            </td>
                        </tr>
                    }
                }
            </tbody>
        </table>
    </div>

    <br />
    <a class="btn btn-primary" asp-controller="Expenses" asp-action="Create">Create New User</a>
</div>
